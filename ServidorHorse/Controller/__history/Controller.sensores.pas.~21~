// REGISTRO DAS ROTAS ========================================================================
procedure Registry;
begin
  // GETS ---------------------------------------------------------
  // LISTAR DADOS
  THorse.Get('/sensores', ListarDados);
  THorse.Get('/sensores/:id', ListarDadosID);
  THorse.Get('/sensores/dados/pluv/:id', ListarDadosPluvID);
  THorse.Get('/sensores/dados/nivel/:id', ListarDadosNivelID);

  // LISTAR MODULOS
  THorse.Get('/sensores/listar/todos', ListarModulosTodos);
  THorse.Get('/sensores/listar/pluv', ListarModulosPluv);
  THorse.Get('/sensores/listar/nivel', ListarModulosNivel);
  THorse.Get('/sensores/listar/alerta', ListarModulosAlerta);

  // CONSULTAR VARIAVEIS
  THorse.Get('/sensores/alerta/mensagem', ConsultaMensagem);

  // ---------------------------------------------------------------


  // POSTS ---------------------------------------------------------
  // ROTA RAIZ (salvar dados que chegam do LoRa no banco de dados)
  THorse.Post('/sensores', SalvarDados);

  // ROTAS SISTEMA DE ALERTA
  THorse.Post('/sensores/alerta/mensagem', DefinirMensagem);
  THorse.Post('/sensores/alerta/nivelvisual', DefinirNivelVisual);
  THorse.Post('/sensores/alerta/nivelsonoro', DefinirNivelSonoro);

  // ---------------------------------------------------------------
end;


// INICIALIZAÇÂO DAS VARIAVEIS =====================================
initialization
  mensagemAlerta := 'CUIDADO|||||ENCHENTE';
  nivelVisual := '0';
  nivelSonoro := '0';

end.
