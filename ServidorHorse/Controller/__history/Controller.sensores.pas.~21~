procedure SalvarDados(Req: THorseRequest; Res: THorseResponse; Next: TProc);
var
    reg : TSensores;
    objRegistro: TJSONObject;
    erro : string;
    body  : TJsonValue;
    locationObj, dataObj, systemObj: TJSONObject;
begin
    // Conexao com o banco...
    try
        reg := TSensores.Create;
    except
        res.Send('Erro ao conectar com o banco').Status(500);
        exit;
    end;

    try
        try
            // Lę o corpo JSON recebido
            body := TJSONObject.ParseJSONValue(TEncoding.UTF8.GetBytes(req.Body), 0) as TJsonValue;

            // Sub-objetos
            //locationObj := body.GetValue<TJSONObject>('location');
            dataObj     := body.GetValue<TJSONObject>('dt');
            //systemObj   := body.GetValue<TJSONObject>('system');

            // ==== DADOS GERAIS ====
            reg.DEVICE_ID   := body.GetValue<string>('id', '');
            reg.DEVICE_TYPE := body.GetValue<string>('tp', '');
            reg.LATITUDE    := -22.9056;
            reg.LONGITUDE   := -47.0610;
            reg.DESCRIPTION := 'Córrego Proença';
            reg.DATETIME    := FormatDateTime('yyyy-mm-dd hh:nn:ss', Now);
            reg.STATUS      := 'Ok';

            // ==== DADOS ESPECÍFICOS ====
            reg.RAIN_MM   := dataObj.GetValue<Double>('Q');
            reg.RAIN_INTENSITY   := dataObj.GetValue<Double>('I');
            reg.WATER_LEVEL   := dataObj.GetValue<Double>('N');

            // ==== DADOS DO SISTEMA ====
            reg.BATTERY_VOLTAGE := 3.88;
            reg.SIGNAL_LORA     := 'Bom';

            reg.Inserir(erro);
            if erro <> '' then raise Exception.Create(erro);

            body.Free;

        except
            on ex: Exception do
            begin
                res.Send('Erro ao salvar dados: ' + ex.Message).Status(400);
                exit;
            end;
        end;

        // ==== Retorno JSON ====
        objRegistro := TJSONObject.Create;
        objRegistro.AddPair('mensagem', 'Dados inseridos com sucesso');
        objRegistro.AddPair('device_id', reg.DEVICE_ID);
        objRegistro.AddPair('tipo', reg.DEVICE_TYPE);

        res.Send<TJSONObject>(objRegistro).Status(201);

    finally
        reg.Free;
    end;
end;

procedure ListarDados(Req: THorseRequest; Res: THorseResponse; Next: TProc);
var
  qry: TFDQuery;
  reg: TSensores;
  erro: string;
  arrayRegistros: TJSONArray;
begin
  try
    reg := TSensores.Create;
  except
    res.Send('Erro ao conectar com o banco. GET /sensores.').Status(500);
    exit;
  end;

  try
    qry := reg.ListarRegistroNivelRio('', erro);
    arrayRegistros := qry.ToJSONArray();

    res.Send<TJSONArray>(arrayRegistros);
  finally
    qry.Free;
    reg.Free;
  end;
end;

procedure ListarDadosID(Req: THorseRequest; Res: THorseResponse; Next: TProc);
var
    reg : TSensores;
    arrayRegistros: TJSONArray;
    qry : TFDQuery;
    erro : string;
begin
    try
        reg := TSensores.Create;
        reg.DEVICE_ID := Req.Params['id'];
    except
        res.Send('Erro ao conectar com o banco').Status(500);
        exit;
    end;

    try
        qry := reg.ListarRegistroNivelRio('', erro);

        if qry.RecordCount > 0 then
        begin
            arrayRegistros := qry.ToJSONArray();
            res.Send<TJSONArray>(arrayRegistros)
        end
        else
            res.Send('Registro năo encontrado').Status(404);
    finally
        qry.Free;
        reg.Free;
    end;
end;

