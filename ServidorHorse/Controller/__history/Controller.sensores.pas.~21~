procedure ConsultaMensagem(Req: THorseRequest; Res: THorseResponse; Next: TProc);
begin
            res.Send(mensagemAlerta).Status(200);
end;

procedure DefinirMensagem(Req: THorseRequest; Res: THorseResponse; Next: TProc);
begin
  mensagemAlerta := req.Body;
  Writeln('Post recebido em /sensores/alerta/mensagem - ' + FormatDateTime('yyyy-mm-dd hh:nn:ss', Now));
  Writeln('Mensagem do sistema de alerta visual alterada para: ' + mensagemAlerta);
  Writeln('');
  res.Send('Recebido. Mensagem alterada para: ' + mensagemAlerta).Status(201);
end;

