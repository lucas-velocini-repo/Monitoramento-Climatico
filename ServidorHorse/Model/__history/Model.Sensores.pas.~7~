function TSensores.ListarModulosTodos(order_by: string; out erro: string): TFDQuery;
var
  qry: TFDQuery;
begin
  try
    qry := TFDQuery.Create(nil);
    qry.Connection := Model.Connection.FConnection;

    with qry do
    begin
      Active := False;
      SQL.Clear;
      SQL.Add('SELECT device_id, description, device_type');
      SQL.Add('FROM devices');
      SQL.Add('WHERE device_id IS NOT NULL');

      SQL.Add('ORDER BY');
      SQL.Add('  SUBSTR(device_id, 1, 1),');
      SQL.Add('  CAST(SUBSTR(device_id, 2) AS INTEGER)');

      Active := True;
    end;

    erro := '';
    Result := qry;

  except
    on ex: Exception do
    begin
      erro := 'Erro ao buscar a lista de todos os módulos: ' + ex.Message;
      Result := nil;
