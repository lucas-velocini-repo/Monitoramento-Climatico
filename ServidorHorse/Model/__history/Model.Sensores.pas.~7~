end;

function TSensores.Excluir(out erro: string): Boolean;
var
  qry: TFDQuery;
begin
  // Validaçăo simples
  if DEVICE_ID.IsEmpty then
  begin
    Result := False;
    erro := 'O DEVICE_ID năo foi informado.';
    Exit;
  end;

  try
    qry := TFDQuery.Create(nil);
    qry.Connection := Model.Connection.FConnection;

    with qry do
    begin
      Active := False;
      SQL.Clear;

      // ==========================
      // Excluir status do sistema
      // ==========================
      SQL.Add('DELETE FROM system_status WHERE device_id = :device_id');
      ParamByName('device_id').AsString := DEVICE_ID;
      ExecSQL;

      // ==========================
      // Excluir mediçőes
      // ==========================
      SQL.Clear;
      SQL.Add('DELETE FROM measurements WHERE device_id = :device_id');
      ParamByName('device_id').AsString := DEVICE_ID;
      ExecSQL;

      // ==========================
      // Excluir dispositivo
      // ==========================
      SQL.Clear;
      SQL.Add('DELETE FROM devices WHERE device_id = :device_id');
      ParamByName('device_id').AsString := DEVICE_ID;
      ExecSQL;
    end;

    qry.Free;
    erro := '';
    Result := True;

  except
    on ex: Exception do
    begin
      erro := 'Erro ao excluir sensor: ' + ex.Message;
      Result := False;
      if Assigned(qry) then
        qry.Free;
    end;
  end;
end;

function TSensores.Inserir(out erro: string): Boolean;
var
  qry: TFDQuery;
begin
  // Validaçăo básica
  if DEVICE_ID.IsEmpty then
  begin
    Result := False;
    erro := 'O DEVICE_ID năo foi informado.';
    Exit;
  end;

  try
    qry := TFDQuery.Create(nil);
    qry.Connection := Model.Connection.FConnection;

    with qry do
    begin
      // =======================
      // Inserir / atualizar device
      // =======================
      Active := False;
      SQL.Clear;
      SQL.Add('INSERT OR IGNORE INTO devices (device_id, device_type, latitude, longitude, description)');
      SQL.Add('VALUES (:device_id, :device_type, :latitude, :longitude, :description)');

      ParamByName('device_id').AsString := DEVICE_ID;
      ParamByName('device_type').AsString := DEVICE_TYPE;
      ParamByName('latitude').AsFloat := LATITUDE;
      ParamByName('longitude').AsFloat := LONGITUDE;
      ParamByName('description').AsString := DESCRIPTION;
      ExecSQL;

      // =======================
      // Inserir mediçőes
      // =======================
      SQL.Clear;
      SQL.Add('INSERT INTO measurements (device_id, timestamp, rain_mm, rain_rate_mm_h, water_level_cm)');
      SQL.Add('VALUES (:device_id, :timestamp, :rain_mm, :rain_rate, :water_level)');

      ParamByName('device_id').AsString := DEVICE_ID;
      ParamByName('timestamp').AsString := DATETIME;
      ParamByName('rain_mm').AsFloat := RAIN_MM;
      ParamByName('rain_rate').AsFloat := RAIN_INTENSITY;
      ParamByName('water_level').AsFloat := WATER_LEVEL;
      ExecSQL;

      // =======================
      // Inserir status do sistema
      // =======================
      SQL.Clear;
      SQL.Add('INSERT INTO system_status (device_id, timestamp, battery_voltage, signal_lora, status)');
      SQL.Add('VALUES (:device_id, :timestamp, :battery_voltage, :signal_lora, :status)');

      ParamByName('device_id').AsString := DEVICE_ID;
      ParamByName('timestamp').AsString := DATETIME;
      ParamByName('battery_voltage').AsFloat := BATTERY_VOLTAGE;
      ParamByName('signal_lora').AsString := SIGNAL_LORA;
      ParamByName('status').AsString := STATUS;
      ExecSQL;
    end;

    qry.Free;
    erro := '';
    Result := True;

  except
    on ex: Exception do
    begin
      erro := 'Erro ao inserir dados do sensor: ' + ex.Message;
      Result := False;
      if Assigned(qry) then
        qry.Free;
    end;
  end;
end;

function TSensores.ListarRegistroChuvaQT(order_by: string; out erro: string): TFDQuery;
var
  qry: TFDQuery;
begin
  try
    qry := TFDQuery.Create(nil);
    qry.Connection := Model.Connection.FConnection;

    with qry do
    begin
      Active := False;
      SQL.Clear;
      SQL.Add('SELECT device_id, timestamp, rain_mm, rain_rate_mm_h');
      SQL.Add('FROM measurements');
      SQL.Add('WHERE rain_mm IS NOT NULL');

      // Se o usuário quiser listar registros de um dispositivo específico
      if not DEVICE_ID.IsEmpty then
      begin
        SQL.Add('AND device_id = :device_id');
        ParamByName('device_id').AsString := DEVICE_ID;
      end;

      // Ordenaçăo — por padrăo, ordem decrescente de data
      if order_by = '' then
        SQL.Add('ORDER BY timestamp DESC')
      else
        SQL.Add('ORDER BY ' + order_by);

      // Limitar a 10 registros
      SQL.Add('LIMIT 10');

      Active := True;
    end;

    erro := '';
    Result := qry;

  except
    on ex: Exception do
    begin
      erro := 'Erro ao consultar registros de chuva: ' + ex.Message;
      Result := nil;
    end;
  end;
end;

